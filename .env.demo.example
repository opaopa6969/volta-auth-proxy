# volta-auth-proxy demo — environment variables
# Copy to .env.demo and fill in your credentials.
#
#   cp .env.demo.example .env.demo
#   docker compose -f docker-compose.demo.yml --env-file .env.demo up --build

# ---------------------------------------------------------------------------
# Base URL
# For local dev, leave as http://localhost
# For a real server, change to https://your-domain.com
# ---------------------------------------------------------------------------
BASE_URL=http://localhost

# ---------------------------------------------------------------------------
# Identity Providers
# Enable the ones you have credentials for.
# Leave blank to disable that provider.
# ---------------------------------------------------------------------------

# Google OAuth 2.0
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Authorized redirect URI: http://localhost/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth App
# Create at: https://github.com/settings/developers → OAuth Apps
# Authorization callback URL: http://localhost/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft / Azure AD
# Create at: https://portal.azure.com/ → App registrations
# Redirect URI: http://localhost/callback
# For personal accounts: MICROSOFT_TENANT_ID=consumers
# For any account:        MICROSOFT_TENANT_ID=common
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ---------------------------------------------------------------------------
# Demo app
# ---------------------------------------------------------------------------
# Comma-separated list of providers shown in the re-auth panel
DEMO_PROVIDERS=GOOGLE,GITHUB,MICROSOFT

# ---------------------------------------------------------------------------
# Optional overrides
# ---------------------------------------------------------------------------
DEV_MODE=true
SESSION_TTL_SECONDS=28800
SUPPORT_CONTACT=demo@example.com
